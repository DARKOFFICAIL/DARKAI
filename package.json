{
  "name": "darkai",
  "version": "1.0.0",
  "description": "AI Code Assistant Desktop Bot - Real-time code analysis and suggestions",
  "main": "src/main/main.js",
  "homepage": "./",
  "author": "DARKOFFICAIL",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start-renderer-dev\" \"wait-on http://localhost:3000 && electron .\"",
    "start-renderer-dev": "cd src/renderer && npm start",
    "build": "npm run build-renderer && npm run build-main",
    "build-renderer": "cd src/renderer && npm run build",
    "build-main": "tsc src/main/main.ts --outDir dist",
    "package": "npm run build && electron-builder",
    "package-win": "npm run build && electron-builder --win",
    "package-mac": "npm run build && electron-builder --mac",
    "package-linux": "npm run build && electron-builder --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.1.0",
    "chokidar": "^3.5.3",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "node-pty": "^0.10.1"
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^latest",
    "electron-devtools-installer": "^3.2.0",
    "concurrently": "^7.6.0",
    "wait-on": "^7.0.1",
    "@types/electron": "^latest",
    "typescript": "^5.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.40.0"
  },
  "build": {
    "appId": "com.darkai.app",
    "productName": "DARKAI",
    "files": [
      "dist/**/*",
      "src/config/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}

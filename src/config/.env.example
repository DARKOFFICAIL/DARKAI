# API Configuration
API_PROVIDER=openai
API_KEY=your-api-key-here
API_MODEL=gpt-4
API_BASE_URL=https://api.openai.com/v1

# Application Configuration
APP_LANGUAGE=ar
APP_DEBUG=false
APP_PORT=9000

# File Monitoring
MONITOR_INTERVAL=1000
MONITOR_BATCH_SIZE=5
MONITOR_ENABLED=true

# AI Settings
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
